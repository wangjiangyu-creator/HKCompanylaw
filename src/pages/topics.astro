---
import BaseLayout from '@/layouts/BaseLayout.astro';
import RecordCard from '@/components/RecordCard.astro';
import { getTopicRecords, topics } from '@/lib/content';
---

<BaseLayout
  title="Topics | Hong Kong Company Law"
  description="A doctrinal topic map for Hong Kong company law."
>
  <section class="page-hero compact-hero">
    <div class="content-wrap">
      <p class="eyebrow">Doctrinal architecture</p>
      <h1>Main Topics</h1>
      <p>
        Each topic frames the core questions, statutory anchors, and curated sources for academic study and practice-aware research.
      </p>
    </div>
  </section>

  <section class="content-wrap topic-index">
    {topics.map((topic) => {
      const records = getTopicRecords(topic.id).slice(0, 4);
      return (
        <article class="topic-panel" id={topic.id}>
          <div class="topic-panel__body">
            <p class="eyebrow">{topic.shortTitle}</p>
            <h2>{topic.title}</h2>
            <p>{topic.summary}</p>
            <div class="anchor-list">
              {topic.statutoryAnchors.map((anchor) => <span>{anchor}</span>)}
            </div>
            <h3>Research questions</h3>
            <ul class="question-list">
              {topic.questions.map((question) => <li>{question}</li>)}
            </ul>
          </div>
          <div class="topic-panel__records">
            <h3>Selected sources</h3>
            {records.map((record) => <RecordCard record={record} />)}
          </div>
        </article>
      );
    })}
  </section>
</BaseLayout>
