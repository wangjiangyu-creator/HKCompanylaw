---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CatalogFilter from './CatalogFilter.astro';
import RecordCard from './RecordCard.astro';
import type { Catalog } from '@/lib/catalog';

const { catalog } = Astro.props as { catalog: Catalog };
const catalogueMetrics = [
  { label: 'Total records', value: catalog.records.length },
  { label: 'Foundational', value: catalog.records.filter((record) => record.importance === 'Foundational').length },
  { label: 'Core', value: catalog.records.filter((record) => record.importance === 'Core').length },
  { label: 'Current', value: catalog.records.filter((record) => record.importance === 'Current').length },
];
---

<BaseLayout title={`${catalog.title} | Hong Kong Company Law`} description={catalog.description}>
  <section class="page-hero compact-hero">
    <div class="content-wrap">
      <p class="eyebrow">{catalog.kicker}</p>
      <h1>{catalog.title}</h1>
      <p>{catalog.description}</p>
    </div>
  </section>
  <section class="content-wrap catalogue-section">
    <div class="catalogue-metrics" aria-label={`${catalog.title} summary`}>
      {catalogueMetrics.map((metric) => (
        <div>
          <strong>{metric.value}</strong>
          <span>{metric.label}</span>
        </div>
      ))}
    </div>
    <CatalogFilter label={`Filter ${catalog.title}`} records={catalog.records} />
    <div class="record-grid">
      {catalog.records.map((record) => <RecordCard record={record} />)}
    </div>
  </section>
</BaseLayout>
